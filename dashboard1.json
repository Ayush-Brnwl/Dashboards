          "rawSql": "SELECT COUNT(*) AS value\n            FROM `db-dev-l4to-mp-github.github_governance.github_audit_pipeline_health`\n            WHERE $__timeFilter(started_at)\n              AND NOT STARTS_WITH(source_file, '_check/')",
