      "targets": [
        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${DS_GITHUB_GOVERNANCE_BIGQUERY}"
          },
          "editorMode": "code",
          "format": 1,
          "rawQuery": true,
          "rawSql": "SELECT\n              SAFE_MULTIPLY(\n                SAFE_DIVIDE(\n                  COUNTIF(processing_status = 'SUCCESS'),\n                  COUNT(*)\n                ),\n                100\n              ) AS value\n            FROM `db-dev-l4to-mp-github.github_governance.github_audit_pipeline_health`\n            WHERE $__timeFilter(started_at)\n              AND NOT STARTS_WITH(source_file, '_check/')",
          "refId": "A",
          "project": "db-dev-l4to-mp-github"
        }
