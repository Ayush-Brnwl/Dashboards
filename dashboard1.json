SELECT
  governance_event_type,
  action,
  actor AS initiated_by,
  org,
  repository,
  COUNT(*) AS events,
  MIN(event_time) AS first_seen,
  MAX(event_time) AS last_seen,
  ARRAY_AGG(DISTINCT review_reason IGNORE NULLS LIMIT 5) AS sample_reasons
FROM `db-dev-l4to-mp-github.github_governance.github_governance_events`
WHERE event_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 180 DAY)
  AND review_priority = 'HIGH'
  AND actor IN (
    'ghemu-landing-zone-factory[bot]',
    'cem401-CPTCLDEG-gh-g_dbk'
  )
GROUP BY
  governance_event_type,
  action,
  initiated_by,
  org,
  repository
ORDER BY events DESC
LIMIT 100;
