SELECT
  governance_event_type,
  action,
  COUNT(*) AS high_priority_events,
  COUNT(DISTINCT org) AS affected_organizations,
  COUNT(DISTINCT repository) AS affected_repositories,
  COUNT(DISTINCT actor) AS initiating_identities,
  MIN(event_time) AS first_seen,
  MAX(event_time) AS last_seen
FROM `db-dev-l4to-mp-github.github_governance.github_governance_events`
WHERE event_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 180 DAY)
  AND review_priority = 'HIGH'
GROUP BY
  governance_event_type,
  action
ORDER BY high_priority_events DESC;

SELECT
  governance_event_type,
  action,
  COALESCE(actor, 'UNKNOWN') AS initiated_by,
  COUNT(*) AS high_priority_events,
  COUNT(DISTINCT repository) AS affected_repositories,
  MIN(event_time) AS first_seen,
  MAX(event_time) AS last_seen
FROM `db-dev-l4to-mp-github.github_governance.github_governance_events`
WHERE event_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 180 DAY)
  AND review_priority = 'HIGH'
GROUP BY
  governance_event_type,
  action,
  initiated_by
ORDER BY high_priority_events DESC
LIMIT 30;

