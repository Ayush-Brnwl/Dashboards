  "description": "Operational health dashboard for the GitHub Governance audit-log processor.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Pipeline health scope",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "**GitHub Governance \u2014 Audit Pipeline Health**  \nTracks GitHub Enterprise audit-log ingestion from GCS into BigQuery: throughput, failures, parse quality, processing duration, and freshness. Non-audit `_check/` marker objects are excluded from health metrics. Source event lag may include historical backfill until backlog processing completes."
      },
      "pluginVersion": "11.6.0",
      "transparent": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Last successful processing age",
      "description": "Seconds since the most recent successful audit-file processing run.",
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "${DS_GITHUB_GOVERNANCE_BIGQUERY}"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 300
              },
              {
                "color": "red",
                "value": 900
              }
            ]
          },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "showPercentChange": false,
        "wideLayout": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${DS_GITHUB_GOVERNANCE_BIGQUERY}"
          },
          "editorMode": "code",
          "format": 1,
          "rawQuery": true,
          "rawSql": "SELECT\n              TIMESTAMP_DIFF(CURRENT_TIMESTAMP(), MAX(completed_at), SECOND) AS value\n            FROM `db-dev-l4to-mp-github.github_governance.github_audit_pipeline_health`\n            WHERE processing_status = 'SUCCESS'\n              AND NOT STARTS_WITH(source_file, '_check/')",
          "refId": "A",
          "project": "db-dev-l4to-mp-github"
        }
      ]
    },
