    {
      "id": 3,
      "type": "stat",
      "title": "Governance Events",
      "description": "Total curated governance events in scope.",
      "datasource": {
        "type": "grafana-bigquery-datasource",
        "uid": "${DS_GITHUB_GOVERNANCE_BIGQUERY}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${DS_GITHUB_GOVERNANCE_BIGQUERY}"
          },
          "editorMode": "code",
          "format": 1,
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM `db-dev-l4to-mp-github.github_governance.github_governance_events` WHERE $__timeFilter(event_time) \n  AND COALESCE(org, '') LIKE $organization\n  AND COALESCE(repository, '') LIKE $repository\n  AND COALESCE(governance_area, '') LIKE $governance_area\n  AND COALESCE(review_priority, '') LIKE $review_priority\n  AND COALESCE(actor, '') LIKE $actor",
          "refId": "A",
          "project": "db-dev-l4to-mp-github"
        }
      ]
    },
