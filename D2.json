          "editorMode": "code",
          "format": 1,
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT actor) AS value FROM `db-dev-l4to-mp-github.github_governance.github_governance_events` WHERE $__timeFilter(event_time) AND actor IS NOT NULL \n  AND COALESCE(org, '') LIKE $organization\n  AND COALESCE(repository, '') LIKE $repository\n  AND COALESCE(governance_area, '') LIKE $governance_area\n  AND COALESCE(review_priority, '') LIKE $review_priority\n  AND COALESCE(actor, '') LIKE $actor",
          "refId": "A",
