      "targets": [
        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${DS_GITHUB_GOVERNANCE_BIGQUERY}"
          },
          "editorMode": "code",
          "format": 1,
          "rawQuery": true,
          "rawSql": "SELECT TIMESTAMP_TRUNC(event_time, DAY) AS time, governance_area AS metric, COUNT(*) AS value\n   FROM `db-dev-l4to-mp-github.github_governance.github_governance_events`\n   WHERE $__timeFilter(event_time) \nAND COALESCE(org, '') LIKE $organization\nAND COALESCE(repository, '') LIKE $repository\nAND COALESCE(governance_area, '') LIKE $governance_area\nAND COALESCE(review_priority, '') LIKE $review_priority\nAND COALESCE(actor, '') LIKE $actor\n\n   GROUP BY time, metric ORDER BY time",
          "refId": "A",
          "project": "db-dev-l4to-mp-github"
        }
      ]
